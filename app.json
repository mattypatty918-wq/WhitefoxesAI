{
  "expo": {
    "name": "Whitefoxes AI",
    "slug": "WhitefoxesAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "whitefoxesai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattypattysapps.whitefoxesai",
      "appId": "com.mattypattysapps.whitefoxesai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a14"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mattypattysapps.whitefoxesai"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}